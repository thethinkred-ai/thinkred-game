# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Stepik OAuth Configuration
# Register your app at https://stepik.org/oauth2/applications/
# The redirect URI in your Stepik app MUST match STEPIK_REDIRECT_URI exactly
STEPIK_CLIENT_ID=your-stepik-client-id
STEPIK_CLIENT_SECRET=your-stepik-client-secret
STEPIK_REDIRECT_URI=http://localhost:3000/auth/stepik/callback
STEPIK_COURSE_ID=0
STEPIK_LESSON_MAP={"lesson_1":0,"lesson_2":0,"lesson_3":0,"lesson_4":0,"lesson_5":0,"lesson_6":0,"lesson_7":0,"lesson_8":0}

# Development: set to true to bypass Stepik lesson gating (dev only)
DEV_UNLOCK_ALL_LESSONS=true

# Database Configuration (sql.js file path)
DATABASE_PATH=./thinkred.db

# Logging
LOG_LEVEL=info
