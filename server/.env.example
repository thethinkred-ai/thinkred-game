# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/thinkred_game
DB_HOST=localhost
DB_PORT=5432
DB_NAME=thinkred_game
DB_USER=username
DB_PASSWORD=password

# Logging
LOG_LEVEL=info
